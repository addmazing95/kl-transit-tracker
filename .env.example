# Copy to .env and adjust as needed.

# Backend
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./data/transit.db
LOG_LEVEL=INFO

# Polling / scheduling
POLL_INTERVAL_SECONDS=20
NEWS_SCRAPE_INTERVAL_MINUTES=15
TIMEZONE=Asia/Kuala_Lumpur

# Data sources
KTMB_GTFS_RT_URL=https://api.data.gov.my/gtfs-realtime/vehicle-position/ktmb
KTMB_GTFS_STATIC_URL=https://api.data.gov.my/gtfs-static/ktmb
PRASARANA_RAIL_STATIC_URL=https://api.data.gov.my/gtfs-static/prasarana?category=rapid-rail-kl
PRASARANA_MRTFEEDER_RT_URL=https://api.data.gov.my/gtfs-realtime/vehicle-position/prasarana?category=rapid-bus-mrtfeeder

# When data.gov.my ships rapid-rail-kl realtime, flip this to true
RAPID_RAIL_LIVE=false

# Frontend
VITE_API_BASE=http://127.0.0.1:8000
VITE_WS_BASE=ws://127.0.0.1:8000
